<Window x:Class="PrintRequestApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Str_MainWindowTitle}"
        FlowDirection="RightToLeft"
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource Str_MainWindowTitle}"
                   FontSize="22" FontWeight="Bold"
                   Margin="0,0,0,16" />

        <!-- Placeholder for the request-level form fields (§8.1 of docs/DESIGN.md) -->
        <GroupBox Grid.Row="1" Header="{DynamicResource Str_RequestDetailsSectionTitle}" Margin="0,0,0,16">
            <TextBlock Text="{DynamicResource Str_RequestDetailsPlaceholder}"
                       TextWrapping="Wrap"
                       Foreground="Gray"
                       Margin="8" />
        </GroupBox>

        <!-- Placeholder for the attachment list section (§8.1 of docs/DESIGN.md) -->
        <GroupBox Grid.Row="2" Header="{DynamicResource Str_AttachmentsSectionTitle}" Margin="0,0,0,16">
            <TextBlock Text="{DynamicResource Str_AttachmentsPlaceholder}"
                       TextWrapping="Wrap"
                       Foreground="Gray"
                       Margin="8" />
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Content="{DynamicResource Str_OpenConfirmationPreview}"
                    Padding="12,6" Margin="0,0,8,0"
                    Click="OpenConfirmationPreview_Click" />
            <Button Content="{DynamicResource Str_SendButton}"
                    Padding="12,6"
                    IsEnabled="False" />
        </StackPanel>
    </Grid>
</Window>
